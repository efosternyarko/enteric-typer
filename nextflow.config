// ── Default parameters ────────────────────────────────────────────────────────
params {
    // Input — one of these is required
    samplesheet   = null
    input_dir     = null

    // Output
    outdir        = 'results'

    // Pathogenwatch integration (requires PW_API_KEY secret or env var)
    run_pathogenwatch                       = false
    pathogenwatch_ecoli_collection_name     = null
    pathogenwatch_salmonella_collection_name= null
    pathogenwatch_ecoli_organism_id         = null   // auto-detected if null
    pathogenwatch_salmonella_organism_id    = null   // auto-detected if null
    pathogenwatch_cluster_thresholds        = '5,10,20,50'
    pathogenwatch_poll_seconds              = 60
    pathogenwatch_max_wait_seconds          = 3600

    // Microreact upload (requires MICROREACT_TOKEN secret or env var)
    upload_microreact  = false
    microreact_project = 'enteric-typer run'

    // Phylogenetics
    ska2_min_samples    = 3      // skip SKA2/IQ-TREE if fewer samples per species
    ska2_prop_filter    = 0.95   // core-genome filter (present in ≥ X fraction of samples)
    iqtree_model        = 'GTR+G'
    iqtree_bootstraps   = 1000
}

// ── Process defaults ──────────────────────────────────────────────────────────
process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.startsWith('NO_FILE') ? null : filename }
    ]

    errorStrategy = { task.exitStatus in [1, 2, 14] ? 'ignore' : 'terminate' }
    maxRetries    = 1

    withLabel: 'low' {
        cpus   = 2
        memory = '4 GB'
        time   = '1h'
    }
    withLabel: 'medium' {
        cpus   = 4
        memory = '16 GB'
        time   = '4h'
    }
    withLabel: 'high' {
        cpus   = 8
        memory = '32 GB'
        time   = '8h'
    }
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    conda {
        conda.enabled  = true
        conda.useMamba = false   // set true if mamba is available (faster solve)
    }

    mamba {
        conda.enabled  = true
        conda.useMamba = true
    }

    docker {
        docker.enabled      = true
        docker.fixOwnership = true
        docker.runOptions   = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${HOME}/.singularity/cache"
        singularity.pullTimeout = '2h'
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'comp'
        withLabel: 'low'    { cpus = 2;  memory = '4 GB';  time = '1h'  }
        withLabel: 'medium' { cpus = 4;  memory = '16 GB'; time = '4h'  }
        withLabel: 'high'   { cpus = 16; memory = '64 GB'; time = '12h' }
    }

    pbs {
        process.executor = 'pbs'
        process.queue    = 'normal'
        withLabel: 'low'    { cpus = 2;  memory = '4 GB';  time = '1h'  }
        withLabel: 'medium' { cpus = 8;  memory = '16 GB'; time = '4h'  }
        withLabel: 'high'   { cpus = 16; memory = '64 GB'; time = '12h' }
    }

    test {
        params.samplesheet       = "${projectDir}/test/samplesheet.csv"
        params.outdir            = 'test_results'
        params.upload_microreact = false
        params.run_pathogenwatch = false
    }
}

// ── Reporting ─────────────────────────────────────────────────────────────────
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite  = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite  = true
}
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag.svg"
    overwrite  = true
}
